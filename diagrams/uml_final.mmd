classDiagram
    class Task {
        +str description
        +str time_str
        +str frequency
        +bool is_completed
        +Optional~date~ last_completed_date
        +mark_complete() None
        +get_next_due_date() Optional~date~
        +__str__() str
    }

    class Pet {
        +str name
        +str species
        +list~Task~ tasks
        +add_task(task: Task) None
        +__str__() str
    }

    class Owner {
        +str name
        +list~Pet~ pets
        +add_pet(pet: Pet) None
        +get_all_tasks() list~tuple~
        +__str__() str
    }

    class Scheduler {
        +Owner owner
        +get_all_tasks() list~tuple~
        +get_pending_tasks() list~tuple~
        +get_completed_tasks() list~tuple~
        +get_tasks_by_pet(pet: Pet) list~Task~
        +get_tasks_by_frequency(frequency: str) list~tuple~
        +sort_by_time(pairs: list) list~tuple~
        +generate_schedule() list~tuple~
        +check_conflicts() list~str~
        +mark_task_complete(task: Task) None
        +reset_daily_tasks() None
        +generate_summary() str
    }

    Owner "1" *-- "many" Pet : owns
    Pet "1" *-- "many" Task : tracks
    Scheduler "1" --> "1" Owner : schedules
